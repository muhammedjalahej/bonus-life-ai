# Copy to .env and fill in your values.
# === Groq LLM ===
GROQ_API_KEY=
LLM_MODEL_NAME=llama-3.1-8b-instant
LLM_TEMPERATURE=0.6

# === Google Gemini (optional – use instead of Groq when set) ===
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# === ElevenLabs (voice agent TTS – required for voice replies) ===
# Get API key from https://elevenlabs.io/app/developers/api-keys
ELEVENLABS_API_KEY=
# Optional: voice ID (default in code: tnSpp4vdxKPjI9w0GnoV). Get from Studio > Voices.
# ELEVENLABS_VOICE_ID=tnSpp4vdxKPjI9w0GnoV
# Optional: model (default: eleven_v3). Or eleven_multilingual_v2.
# ELEVENLABS_MODEL_ID=eleven_v3

# === Server ===
HOST=0.0.0.0
PORT=8001
RELOAD=True
FRONTEND_URL=http://localhost:5173

# Production: set RELOAD=False, FRONTEND_URL=https://your-app.vercel.app

# === JWT ===
JWT_SECRET=change-this-to-a-long-random-string

# === Database (leave blank to use SQLite on the /app/data volume) ===
DATABASE_URL=

# === Stripe (subscription demo) ===
# Secret key (sk_test_...) from Stripe Dashboard. NOT rk_test_ (restricted).
# Create a Product, add recurring Prices, then paste the Price IDs (price_...).
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID_PRO_MONTHLY=price_1T4SO13GwPJnmgaRYJmYHV2w
STRIPE_PRICE_ID_PRO_YEARLY=price_1T4SVw3GwPJnmgaRR2hHvU2d
STRIPE_WEBHOOK_SECRET=
